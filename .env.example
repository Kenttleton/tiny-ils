# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# --- First-run bootstrap ---
# Set this to an email address to automatically create the first MANAGER on startup.
# Once a manager exists, this variable is ignored.
BOOTSTRAP_MANAGER_EMAIL=admin@yourlibrary.local

# --- Session security ---
# A long random string used to sign session cookies in the BFF.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=changeme-use-openssl-rand-hex-32

# --- SSO: Google OAuth 2.0 (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the redirect URI to http://localhost:3001/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Metadata enrichment API keys (optional) ---
# TMDB (movies/video) — free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# IGDB (games) — free via Twitch, see https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
